NODE_ENV=development
APP_NAME=cukong-markets
PUBLIC_BASE_URL=
APP_PORT=3000
APP_BIND_HOST=0.0.0.0

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOWED_USER_IDS=123456789
LOG_LEVEL=info

DATA_DIR=./data
LOG_DIR=./logs
TEMP_DIR=./tmp

INDODAX_PUBLIC_BASE_URL=https://indodax.com/api
INDODAX_PRIVATE_BASE_URL=https://indodax.com/tapi
INDODAX_TRADE_API_V2_BASE_URL=https://tapi.indodax.com
INDODAX_TIMEOUT_MS=15000
# outbound request pacing guard (ms antar request)
INDODAX_PUBLIC_MIN_INTERVAL_MS=250
INDODAX_PRIVATE_MIN_INTERVAL_MS=300
INDODAX_HISTORY_MODE=v2_only

INDODAX_CALLBACK_PATH=/indodax/callback
INDODAX_CALLBACK_PORT=3001
INDODAX_CALLBACK_BIND_HOST=0.0.0.0
INDODAX_CALLBACK_ALLOWED_HOST=
INDODAX_ENABLE_CALLBACK_SERVER=false

POLLING_INTERVAL_MS=5000
MARKET_WATCH_INTERVAL_MS=10000
HOTLIST_LIMIT=15
MAX_PAIRS_TRACKED=250

DEFAULT_TRADING_MODE=ALERT_ONLY
DEFAULT_QUOTE_ASSET=idr

RISK_MAX_OPEN_POSITIONS=3
RISK_MAX_POSITION_SIZE_IDR=100000
RISK_MAX_PAIR_SPREAD_PCT=1.25
RISK_COOLDOWN_MS=900000

WORKER_ENABLED=true
WORKER_POOL_SIZE=2

SCANNER_HISTORY_LIMIT=300
ORDERBOOK_DEPTH_LEVELS=20
TRADE_CLUSTER_WINDOW_MS=15000

PROBABILITY_THRESHOLD_AUTO=0.72
CONFIDENCE_THRESHOLD_AUTO=0.68
SPOOF_RISK_BLOCK_THRESHOLD=0.55
BUY_SLIPPAGE_BPS=60
MAX_BUY_SLIPPAGE_BPS=150
BUY_ORDER_TIMEOUT_MS=8000
